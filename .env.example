# Project paths
DATA_RAW_PATH=data/raw/Movie reviews.csv
DATA_PROCESSED_DIR=data/processed
MODEL_DIR=models
REPORT_DIR=reports

# Reproducibility
RANDOM_SEED=42
MAX_WORDS=10000
MAX_SEQUENCE_LENGTH=100
TEST_SIZE=0.10
VALIDATION_SIZE=0.10

# Optional experiment tracking
MLFLOW_TRACKING_URI=
